{
  "compilerOptions": {
    "target": "ES2022",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "lib": ["ES2022"],
    "types": ["node"],

    // The point of the demo: `strict` makes the type system enforce the same
    // discipline that keeps V8's speculation monomorphic and type-stable.
    "strict": true,

    // A few extra strict-adjacent checks (not implied by `strict`).
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,

    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": ["ts/**/*.ts"]
}
